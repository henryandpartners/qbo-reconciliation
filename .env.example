# QBO Environment Variables (LOCAL ONLY — never commit)
# Copy this file to .env.local and fill in your values

# ── QuickBooks Online API Credentials (from Intuit Developer Portal Keys tab) ──
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
QBO_REDIRECT_URI="https://qbo-reconciliation-jade.vercel.app/auth/callback"
QBO_COMPANY_ID="9341453354898311"

# ── Access Tokens (regenerated via OAuth each session — never hardcoded) ──
# These are ephemeral. Get fresh ones from https://qbo-reconciliation-jade.vercel.app
# QBO_ACCESS_TOKEN=""
# QBO_REFRESH_TOKEN=""
